msgid "Send email"
msgstr "Tumizani imelo"

#: plugins/thunar-sendto-email/main.c:217
#: plugins/thunar-sendto-email/main.c:237
msgid "Send _directly"
msgstr "Tumizani _choncho"

#: plugins/thunar-sendto-email/main.c:218
msgid "Send com_pressed"
msgstr "Tumizani zoche_petsedwa"

#: plugins/thunar-sendto-email/main.c:220
msgid ""
"When sending a file via email, you can either choose to send the file "
"directly, as is, or compress the file before attaching it to an email. It is "
"highly recommended to compress large files before sending them."
msgstr ""
"Pamene mukutumiza fayilo ku imelo, mutha kusankha kutumiza fayilo payokha, "
"kapena kuchepetsa fayilo musanaiyike ku imelo. Ndizolimbikitsidwa kwambiri "
"kuchepetsa mafayilo akulu akulu musanawatumize."

#: plugins/thunar-sendto-email/main.c:231
#, c-format
msgid "Send %d file as compressed archive?"
msgid_plural "Send %d files as compressed archive?"
msgstr[0] "Mufuna kutumiza fayilo %d mopakiza mu chikwatu?"
msgstr[1] "Mufuna kutumiza mafayilo %d mopakiza mu chikwatu?"

#: plugins/thunar-sendto-email/main.c:238
msgid "Send as _archive"
msgstr "Tumizani _mopakiza mu chikwatu"

#: plugins/thunar-sendto-email/main.c:240
msgid ""
"When sending multiple files via email, you can either choose to send the "
"files directly, attaching multiple files to an email, or send all files "
"compressed into a single archive file and attach the archive. It is highly "
"recommended to send multiple large files as archive."
msgstr ""
"Pamene mukutumiza mafayilo ambiri ku imelo, mutha kusankha kutumiza mafayilo "
"pawokha, kapena kuphatikiza mafayilo angapo ku imelo, kapena kutumiza ma "
"fayilo onse ophatikana mopakiza mu fayilo imodzi. Ndizolimbikitsidwa "
"kwambiri kutumiza mafayilo akulu akulu mopakiza mu chikwatu cha fayilo "
"imodzi."

